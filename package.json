{
  "name": "kiwi-control-workspace",
  "version": "0.2.0-beta.9",
  "private": true,
  "type": "module",
  "description": "Kiwi Control workspace for a repo-first local control plane",
  "workspaces": [
    "packages/sj-core",
    "packages/sj-cli",
    "apps/sj-ui"
  ],
  "scripts": {
    "build": "npm run build -w @shrey-junior/sj-core && npm run build -w shrey-junior && npm run build -w @shrey-junior/sj-ui",
    "test": "npm run test -w shrey-junior && npm run test -w @shrey-junior/sj-ui",
    "test:ui": "npm run test -w @shrey-junior/sj-ui",
    "test:installer:launch": "node scripts/verify-installed-launch-flow.mjs",
    "test:installer:bundled-cli:macos": "node scripts/verify-bundled-cli-install.mjs --platform macos --scope machine",
    "test:installer:bundled-cli:windows": "node scripts/verify-bundled-cli-install.mjs --platform windows --scope machine",
    "test:installer:cli-enable:macos": "node scripts/verify-installed-cli-enable-flow.mjs --platform macos",
    "test:installer:cli-enable:windows": "node scripts/verify-installed-cli-enable-flow.mjs --platform windows",
    "test:installer:pkg:macos": "node scripts/verify-macos-pkg-install.mjs",
    "media:generate": "node scripts/generate-product-media.mjs",
    "test:core:features": "bash scripts/test-core-features.sh",
    "test:cli:features": "bash scripts/test-cli-features.sh",
    "test:desktop:rendered": "node scripts/verify-rendered-desktop.mjs",
    "test:desktop:features": "bash scripts/test-desktop-features.sh",
    "test:product:features": "bash scripts/test-product-features.sh",
    "clean:macos-sidecars": "bash scripts/clean-macos-sidecars.sh",
    "cli": "node scripts/run-cli.mjs",
    "audit": "npm run build && node packages/sj-cli/dist/cli.js audit",
    "check": "npm run build && node packages/sj-cli/dist/cli.js check",
    "smoke": "npm run build && bash scripts/smoke-test.sh",
    "runtime:stage": "node scripts/prepare-runtime-sidecar.mjs",
    "release:manifest": "npm run build -w @shrey-junior/sj-core && node scripts/prepare-release-manifest.mjs",
    "release:checksums": "node scripts/generate-release-checksums.mjs",
    "release:package-assets": "node scripts/package-release-assets.mjs",
    "site:ensure:aws": "node scripts/ensure-aws-public-site.mjs",
    "release:publish:aws": "node scripts/publish-aws-public-downloads.mjs",
    "release:downloads:github": "node scripts/generate-github-release-downloads.mjs",
    "release:homebrew": "node scripts/generate-homebrew-tap.mjs",
    "release:verify-artifacts": "node scripts/verify-release-artifacts.mjs",
    "release:verify:public-downloads": "node scripts/verify-public-download-surface.mjs",
    "release:trust": "node scripts/verify-release-trust.mjs",
    "oss:check": "node scripts/verify-open-source-readiness.mjs",
    "release:check": "npm run test:product:features && npm run release:manifest && npm run release:checksums",
    "site:stage": "node scripts/stage-pages-site.mjs",
    "site:publish:aws": "node scripts/publish-aws-public-site.mjs",
    "ui:dev": "node scripts/run-ui-dev.mjs",
    "ui:build": "npm run build -w @shrey-junior/sj-ui",
    "ui:desktop:build": "node scripts/run-ui-desktop-build.mjs",
    "ui:desktop:build:release": "node scripts/run-ui-desktop-build.mjs",
    "ui:desktop:test": "node scripts/run-ui-desktop-test.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "^5.8.3"
  }
}
