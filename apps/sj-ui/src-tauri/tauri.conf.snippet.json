{
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kiwi Control",
        "width": 1320,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis",
      "msi",
      "appimage"
    ],
    "createUpdaterArtifacts": false,
    "externalBin": [
      "binaries/kiwi-control-runtime"
    ],
    "resources": {
      "resources/desktop/": "desktop/"
    }
  },
  "plugins": {}
}
